WORKFLOW hello_world
  INPUT @languages LIST, @greeting TEXT
  OUTPUT @results LIST
DO
  @results := LIST();
  @index := 0;
  @count := 5;
  WHILE @index < @count DO
    @language := GET(@languages, @index);
    @translation := '';
    GENERATE translate(@greeting, @language) INTO @translation;
    @results := APPEND(@results, @translation);
    @index := @index + 1;
  END;
  COMMIT @results;
END;