-- improve_code.spl
-- Sub-workflow: improve code given review feedback and test results.

WORKFLOW improve_code
    INPUT:  @code TEXT, @feedback TEXT, @test_result TEXT
    OUTPUT: @improved TEXT
DO
    GENERATE refactor(@code, @feedback, @test_result) INTO @improved
    LOGGING 'improve_code: revision complete' LEVEL DEBUG
    RETURN @improved
END
