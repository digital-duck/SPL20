-- generate_code.spl
-- Sub-workflow: generate Python code from a natural-language specification.

WORKFLOW generate_code
    INPUT:  @spec TEXT
    OUTPUT: @code TEXT
DO
    LOGGING f'generate_code: spec={@spec}' LEVEL DEBUG
    GENERATE coder(@spec) INTO @code
    LOGGING 'generate_code: implementation produced' LEVEL DEBUG
    RETURN @code
END
