import nltk # Natural Language Toolkit library

from nltk.sentiment.vader import SentimentIntensityAnalyzer # Vader sentiment intensity analyzer tool from NLTK's sentiment analysis library
import pandas as pd # pandas data manipulation and analysis library
import numpy as np # NumPy library for numerical computations

def batch_sentiment(input_string):
    """
    Batch sentiment analysis function.
    
    Parameters:
    input_string (str): The input string to analyze.
    
    Returns:
    list: A list of dictionaries containing the cleaned sentence and its corresponding sentiment scores.
    """

    # Split the input string into individual sentences
    sentences = input_string.split('.')

    # Clean each sentence by removing leading/trailing whitespace and converting to lowercase
    cleaned_sentences = [sentence.strip().lower() for sentence in sentences if sentence.strip() != '']

    si = SentimentIntensityAnalyzer() # Initialize a SentimentIntensityAnalyzer object

    # Initialize an empty list to store the results
    results = []

    # Iterate over each cleaned sentence
    for sentence in cleaned_sentences:
        # Analyze the sentiment of the sentence
        sentiment_scores = si.polarity_scores(sentence)
        
        # Extract the compound sentiment score
        compound_score = sentiment_scores['compound']

        # Determine the overall sentiment based on the compound score
        if compound_score >= 0.05:
            sentiment = 'Positive'
        elif compound_score <= -0.05:
            sentiment = 'Negative'
        else:
            sentiment = 'Neutral'

        # Store the results in a dictionary
        result = {
            'Cleaned Sentence': sentence,
            'Sentiment': sentiment,
            'Compound Score': compound_score
        }

        # Append the result to the list of results
        results.append(result)

    return results

# Test the function with the provided inputs
input1 = "Great product, love it! | Terrible experience, never again | It was okay I guess"
