-- Recipe 31: Sentiment Pipeline
-- Batch sentiment over a list of inputs, aggregate trend statistics.
-- Demonstrates iteration over a list with per-item structured output + aggregation.
--
-- Usage:
--   spl2 run cookbook/31_sentiment_pipeline/sentiment.spl --adapter ollama -m gemma3 \
--       items="Great product, love it! | Terrible experience, never again | It was okay I guess"
--
--   spl2 run cookbook/31_sentiment_pipeline/sentiment.spl --adapter ollama \
--       items="$(cat reviews.txt)" delimiter="\n" domain="product_reviews"

CREATE FUNCTION sentiment_schema()
RETURNS JSON AS $$
{
  "type": "object",
  "properties": {
    "label":      {"type": "string", "enum": ["positive", "negative", "neutral", "mixed"]},
    "score":      {"type": "number", "minimum": -1, "maximum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "emotions":   {"type": "array", "items": {"type": "string"}},
    "key_phrases":{"type": "array", "items": {"type": "string"}}
  },
  "required": ["label", "score", "confidence"]
}
$$;

WORKFLOW sentiment_pipeline
    INPUT: @items TEXT, @delimiter TEXT DEFAULT '|', @domain TEXT DEFAULT 'general'
    OUTPUT: @report TEXT
DO
    -- Step 1: Parse and clean the input list
    GENERATE split_and_clean(@items, @delimiter) INTO @item_list

    -- Step 2: Batch sentiment analysis (one result per item)
    GENERATE batch_sentiment(@item_list, sentiment_schema(), @domain) INTO @sentiment_results

    -- Step 3: Aggregate statistics
    GENERATE compute_sentiment_stats(@sentiment_results) INTO @stats_json

    -- Step 4: Identify notable items
    GENERATE find_extremes(@sentiment_results) INTO @extremes

    -- Step 5: Generate trend summary
    GENERATE summarize_sentiment_trends(
        @stats_json,
        @extremes,
        @domain
    ) INTO @trend_summary

    -- Step 6: Assemble full report
    GENERATE assemble_sentiment_report(
        @sentiment_results,
        @stats_json,
        @trend_summary,
        @extremes
    ) INTO @report

    COMMIT @report WITH status = 'complete', domain = @domain

EXCEPTION
    WHEN ContextLengthExceeded THEN
        -- Too many items — report stats only
        GENERATE compute_sentiment_stats(@sentiment_results) INTO @stats_json
        COMMIT @stats_json WITH status = 'stats_only', reason = 'too_many_items'
END
```

