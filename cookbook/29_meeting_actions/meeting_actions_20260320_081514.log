import re

def extract_actions(action_item_schema):
    # Assuming action_item_schema is a dictionary with 'name' and 'text' keys
    if not isinstance(action_item_schema, dict) or 'name' not in action_item_schema or 'text' not in action_item_schema:
        raise ValueError("Invalid schema")

    extracted_action = {
        "name": action_item_schema['name'],
        "text": action_item_schema['text']
    }

    return extracted_action

