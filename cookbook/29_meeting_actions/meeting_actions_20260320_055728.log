import re

def extract_actions(input_text):
    # Convert all names into standard form (all caps)
    input_text = input_text.upper()

    # Remove punctuation and special characters from the text
    input_text = re.sub(r'[^\w\s]', '', input_text)

    # Replace multiple spaces with a single space
    input_text = re.sub(r'\s+', ' ', input_text)

    # Convert all words to lowercase
    input_text = input_text.lower()

    # Split the text into lines
    lines = input_text.split('\n')

    # Initialize an empty list to store the actions
    actions = []

    # Check if each line is an action
    for i in range(0, len(lines), 2):
        speaker_name = None
        action = ''

        # Extract the speaker's name and action from the current line
        if lines[i].strip():
            speaker_name = re.search(r'([A-Z]+):', lines[i]).group(1)
        else:
            speaker_name = 'Unknown'

        if lines[i+1]:
            action = lines[i+1]

        # Add the action to the list
        actions.append((speaker_name, action))

    return actions
