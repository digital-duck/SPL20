def extract_actions(transcript):
    # Define a pattern for actions
    action_pattern = r': \w*'

    # Find all matches of the action pattern in the transcript
    actions = [match.strip().split(': ')[1] for match in transcript.split('\n') if action_pattern in match]

    return actions

transcript = """
alice: we need to fix the login bug before friday.
bob: i'll handle it.
alice: also need to update the docs
"""

actions = extract_actions(transcript)
print(actions)
