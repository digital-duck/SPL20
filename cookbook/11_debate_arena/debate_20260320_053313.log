class ProArgument:
    def __init__(self, topic, key_points=None, rebuttals=None):
        self.topic = topic
        if key_points is not None and not isinstance(key_points, list):
            raise ValueError("Key points must be a list")
        self.key_points = key_points if key_points is not None else []
        if rebuttals is not None and not isinstance(rebuttals, list):
            raise ValueError("Rebuttals must be a list")
        self.rebuttals = rebuttals if rebuttals is not None else []

    def present_argument(self):
        print(f"Argument in favor of {self.topic}:")
        
        ProArgument._present_introduction()
        
        ProArgument._present_key_points()

        ProArgument._present_conclusion()

    @staticmethod
    def _present_introduction():
        print("\nIntroduction:")
        print("- Argument in favor of opening AI to the public.")

    @staticmethod
    def _present_key_points():
        print("\nKey Points:")
        for point_number, point in enumerate(self.key_points, start=1):
            print(f"- Point {point_number}: {point}")
            if self.rebuttals:
                ProArgument._present_rebuttal(point_number)

    @staticmethod
    def _present_conclusion():
        print("\nConclusion:")
        print("- Making AI open-sourced is crucial for promoting innovation, transparency, and human-AI collaboration.")

    @staticmethod
    def get_key_point(point_number):
        return ProArgument._key_points[point_number - 1]

    @staticmethod
    def _key_points():
        return [
            "Open-sourcing AI promotes collaboration and accelerates research.",
            "By making AI code available, we can ensure transparency and accountability in AI decision-making."
        ]

    @staticmethod
    def _rebuttals():
        return [
            "However, some argue that open-sourcing AI could compromise security by exposing sensitive code to potential vulnerabilities.",
            "Others argue that open-sourcing AI would disrupt the competitive advantage of industries that have invested heavily in proprietary AI technologies."
        ]


