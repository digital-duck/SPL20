WORKFLOW review_agent
  INPUT @draft TEXT
  OUTPUT @final TEXT
DO
  @quality := 0.0;
  @current := @draft;
  WHILE @quality < 0.8 DO
    GENERATE rewrite(@current, style='improved') INTO @current;
    GENERATE sentiment(@current) INTO @quality;
  END;
  @final := @current;
  COMMIT @final;

CREATE FUNCTION rewrite(
  input TEXT,
  style TEXT DEFAULT 'standard'
)
RETURNS TEXT AS $$
  CASE style
    WHEN 'improved' THEN
      REPLACE(input, 'this', 'that')
    WHEN 'formal' THEN
      REPLACE(input, 'is', 'are')
  END;
$$;

CREATE FUNCTION sentiment(
  input TEXT
)
RETURNS NUMBER AS $$
  RETURN LENGTH(REPLACE(input, ',', '')) / LENGTH(input);
$$;