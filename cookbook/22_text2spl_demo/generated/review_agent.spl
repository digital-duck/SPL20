WORKFLOW refine_text
  INPUT @draft TEXT
  OUTPUT @final TEXT
DO
  DO
    GENERATE rewrite(@draft, style='improved') INTO @temp;
    GENERATE sentiment(@temp) INTO @quality;
    IF @quality < 0.8 THEN
      BREAK;
    END;
  EXCEPTION
    WHEN HallucinationDetected THEN
      @final := 'unknown';
      COMMIT @final;
    WHEN ContextLengthExceeded THEN
      RETRY;
  END;
  GENERATE summarize(@temp) INTO @summary;
  IF @quality < 0.8 AND @summary LIKE '%needs improvement%' THEN
    GENERATE rewrite(@temp, style='refined') INTO @temp_refined;
    GENERATE sentiment(@temp_refined) INTO @quality;
    IF @quality <= 0.8 THEN BREAK; 
  END;
  @final := @temp_refined;
  COMMIT @final;
END;