WORKFLOW refine_text
  INPUT @draft TEXT
  OUTPUT @final TEXT
DO
  @quality := summarize(@draft);
  WHILE @quality < 0.8 DO
    GENERATE rewrite(@draft, style='improved') INTO @temp;
    GENERATE sentiment(@temp) INTO @new_quality;
    IF @new_quality > @quality THEN
      @quality := @new_quality;
      @draft := @temp;
    END;
  END;
  @final := @draft;
  COMMIT @final;
END;

CREATE FUNCTION summarize(input TEXT)
RETURNS NUMBER AS $$
  sum([token] FOR token IN split(input, ' '))
$$;

CREATE FUNCTION rewrite(input TEXT, style TEXT)
RETURNS TEXT AS $$
  CASE style
    WHEN 'improved' THEN replace(replace(input, 'not a good word', 'a better one'), 'not a great phrase', 'an even better one')
    ELSE input
  END;
$$;

CREATE FUNCTION sentiment(input TEXT)
RETURNS NUMBER AS $$
  (sum([token] FOR token IN split(input, ' ') WHERE token IN ['good', 'great']) - sum([token] FOR token IN split(input, ' ') WHERE token IN ['bad', 'terrible'])) / length(split(input, ' '))
$$;

CREATE FUNCTION split(input TEXT, delimiter TEXT)
RETURNS LIST<TEXT> AS $$
  list([token] FOR token IN split(input, delimiter))
$$;