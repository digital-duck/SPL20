WORKFLOW refine_text
  INPUT @draft TEXT
  OUTPUT @final TEXT
DO
  @quality := summarize(@draft);
  WHILE @quality < 0.8 DO
    GENERATE rewrite(@draft) INTO @temp;
    GENERATE sentiment(@temp) INTO @new_quality;
    IF @new_quality > @quality THEN
      @quality := @new_quality;
      @draft := @temp;
    END IF;  -- Added 'IF'
  END;
  @final := @draft;
  COMMIT @final;

CREATE FUNCTION summarize(text TEXT)
RETURNS NUMBER AS $$
  sum(1.0 for token in split(text, ' ') if length(token) > 3)
$$;

CREATE FUNCTION rewrite(text TEXT)
RETURNS TEXT AS $$
  replace('bad', 'good', text)
$$;

CREATE FUNCTION sentiment(text TEXT)
RETURNS NUMBER AS $$
  (sum(1.0 for word in split(text, ' ') if word:is upper) - sum(1.0 for word in split(text, ' ') if word:is lower)) / length(split(text, ' '))
$$;