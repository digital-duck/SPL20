PROMPT classify_intent WITH BUDGET 100 TOKENS
SELECT @input AS text LIMIT 50 TOKENS
GENERATE extract_entities(@text) INTO @entities;
WHEN @entities = 'user_request' THEN
  CALL intent_handler('request')
WHEN @entities = 'product_query' THEN
  CALL intent_handler('query')
ELSE
  CALL intent_handler('unknown')