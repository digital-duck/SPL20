WORKFLOW classify_intent
  INPUT @text TEXT
  OUTPUT @intent TEXT
DO
  @category := CLASSIFY(@text) INTO @intent;
  IF @intent = 'question' THEN
    GENERATE answer(@text) INTO @response;
    COMMIT @response;
  ELSEIF @intent = 'order' THEN
    GENERATE rewrite(@text, style='formal') INTO @formatted_text;
    COMMIT @formatted_text;
  ELSE
    @intent := 'unknown';
    COMMIT @intent;
  END;
EXCEPTION
  WHEN HallucinationDetected THEN
    @intent := 'unknown';
    COMMIT @intent;
END;