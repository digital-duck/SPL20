PROMPT classify_intent
SELECT @input AS text LIMIT 100 TOKENS,
       'user intent' AS category
GENERATE classify(text, category) WITH OUTPUT BUDGET 500 TOKENS INTO @result;

WORKFLOW route_handler
  INPUT @input TEXT
  OUTPUT @handler TEXT
DO
  EVALUATE
    WHEN @result = 'greeting' THEN
      CALL greet_user(@input)
    WHEN @result = 'question' THEN
      CALL answer_question(@input)
    ELSE
      CALL unknown_intent(@input)
  END;
END;