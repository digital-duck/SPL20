WORKFLOW refine_text
  INPUT @draft TEXT
  OUTPUT @final TEXT
DO
  @quality := 0.0;
  @current := @draft;
  WHILE @quality < 0.8 DO
    GENERATE rewrite(@current, style='improved') INTO @temp;
    GENERATE sentiment(@temp) INTO @new_quality;
    IF @new_quality > @quality THEN
      @quality := @new_quality;
      @current := @temp;
    END;
  END;
  @final := @current;
  COMMIT @final;

CREATE FUNCTION rewrite(text TEXT, style TEXT)
RETURNS TEXT AS $$
  CASE style
    WHEN 'improved' THEN text || '.'
    ELSE text
  END;
$$;

CREATE FUNCTION sentiment(text TEXT) RETURNS NUMBER AS $$
  CAST(SPLIT(text, ' ')[1] AS NUMBER);
$$