-- Recipe 48: Credit Risk Assessment
-- Demonstrates: EVALUATE branching, CALL/GENERATE split, deterministic routing
PROMPT analyze_risk_factors
SELECT
  system_role('You are a senior credit risk analyst at a Tier-1 bank.'),
  context.applicant_data AS data
GENERATE analyze(data)

WORKFLOW credit_risk_assessment
INPUT:
  @applicant_data TEXT,
  @credit_score INTEGER
OUTPUT: @decision TEXT
DO
  LOGGING f'Assessing applicant | score={@credit_score}' LEVEL INFO

  -- Step 1: Deterministic Guard (WHERE clause equivalent)
  EVALUATE @credit_score
  WHEN < 600 THEN
    LOGGING 'Auto-reject: Low credit score' LEVEL WARN
    COMMIT 'REJECTED' WITH reason = 'score_below_threshold', score = @credit_score
  WHEN >= 750 THEN
    LOGGING 'Auto-approve: High credit score' LEVEL INFO
    COMMIT 'APPROVED' WITH reason = 'score_excellent', score = @credit_score
  ELSE
    LOGGING 'Score in gray zone → triggering qualitative review' LEVEL INFO
  END

  -- Step 2: Qualitative LLM Analysis (SELECT equivalent)
  GENERATE analyze_risk_factors(@applicant_data) INTO @risk_report
  
  -- Step 3: Deterministic Extraction (Zero token cost)
  CALL extract_risk_rating(@risk_report) INTO @risk_rating
  
  LOGGING f'Extracted risk rating: {@risk_rating}' LEVEL DEBUG

  -- Step 4: Final Routing
  EVALUATE @risk_rating
  WHEN 'high' THEN
    COMMIT 'REJECTED' WITH reason = 'qualitative_risk_high', report = @risk_report
  WHEN 'medium' THEN
    COMMIT 'MANUAL_REVIEW' WITH reason = 'qualitative_risk_medium', report = @risk_report
  ELSE
    COMMIT 'APPROVED' WITH reason = 'qualitative_risk_low', report = @risk_report
  END

EXCEPTION
  WHEN ConnectionError THEN
    LOGGING 'External data source unavailable' LEVEL ERROR
    COMMIT 'PENDING' WITH reason = 'system_error'
END