import random

# Define a dictionary to store questions and answers
questions = {
    "Senior Software Engineer": [
        {"question": "Can you explain the concept of encapsulation?", "answer": "Encapsulation is a fundamental principle in object-oriented programming that binds data and methods that operate on that data into a single unit."},
        {"question": "How do you handle errors in your code?", "answer": "I use try-except blocks to catch and handle exceptions."},
        {"question": "Can you describe the differences between monolithic and microservices architecture?", "answer": "Monolithic architecture is a single, self-contained application, while microservices architecture is a collection of smaller services that communicate with each other."}
    ],
    "Junior Software Engineer": [
        {"question": "Can you explain the concept of variables in programming?", "answer": "Variables are used to store and manipulate data in a program."},
        {"question": "How would you approach debugging a code issue?", "answer": "I would use print statements and debuggers to identify the source of the error."},
        {"question": "Can you describe the differences between Python and Java?", "answer": "Python is a high-level language with a focus on simplicity and ease of use, while Java is an object-oriented language with a focus on platform independence."}
    ],
    # Add more positions and questions as needed
}

# Define a function to score answers
def score_answer(question_set):
    score = 0
    for question in question_set:
        print(f"\nQuestion: {question['question']}")
        
        if 'key' in question:
            if 'approach' in question:
                print(f"As a {question['key']} with an {question['approach']} approach, you might ask: ")
                print(question["question"])
            
        answer = input("Your Answer: ")

        if answer.lower() == question["answer"].lower():
            print("Correct!\n")
            score += 1
        else:
            print(f"Incorrect. The correct answer is: \n{question['answer']}\n")

    return score

# Define a function to generate random questions
def ask_question(position, topic):
    if position in questions and topic in questions[position]:
        question_set = questions[position]
        if 'key' in question_set[0]:
            if 'approach' in question_set[0]:
                print(f"As a {question_set[0]['key']} with an {question_set[0]['approach']} approach, you might ask: ")
                random_question = random.choice(question_set)
                print(random_question["question"])
        else:
            random_question = random.choice(question_set)
        
        score = score_answer([random_question])
        return score
    else:
        return "Invalid position or topic"

# Example usage:
position = "Senior Software Engineer"
topic = "system design"

score = ask_question(position, topic)
print(f"\nYour final score is: {score}")
```

In this implementation:

*   We define a dictionary `questions` to store questions and answers for different positions.
*   The `score_answer` function takes a list of questions as input and scores the user's answer. It returns the total score based on correct answers.
*   The `ask_question` function generates random questions from the specified position and topic. It asks the user for their answer and checks if it matches the correct answer, scoring it accordingly.
*   We use a random question selection to simulate different scenarios for the user.

Note that this implementation uses a simple scoring system where each correct answer is assigned a score of 1. You can modify the scoring system as needed to suit your requirements.
