import random

def generate_question_set(role, topic, interviewer_persona):
    """
    Generates a list of potential questions based on the provided inputs.

    Args:
        role (str): The candidate's role.
        topic (str): The system design topic.
        interviewer_persona (dict): A dictionary containing the interviewer's persona.

    Returns:
        list: A list of potential questions.
    """

    # Define a dictionary with question categories
    question_categories = {
        "design": [
            {"question": "What is your approach to designing a scalable database schema?", 
             "score": 5},
            {"question": "How would you handle high traffic in a web application?", 
             "score": 8},
            {"question": "Can you explain the trade-offs between ACID and BASE?", 
             "score": 6}
        ],
        "architecture": [
            {"question": "Describe your experience with microservices architecture.", 
             "score": 7},
            {"question": "How do you determine the right level of granularity for a system design?", 
             "score": 8},
            {"question": "What are some common pitfalls to avoid when designing a distributed system?", 
             "score": 9}
        ],
        "performance": [
            {"question": "How would you optimize the performance of a query in a database?", 
             "score": 6},
            {"question": "Can you explain the concept of caching and its benefits?", 
             "score": 8},
            {"question": "How do you handle scalability issues in a high-traffic application?", 
             "score": 9}
        ]
    }

    # Determine the topic category based on the provided topic
    if topic == "system design":
        topic_category = "design"
    elif topic == "database systems" or topic == "data storage":
        topic_category = "design"
    elif topic == "cloud computing":
        topic_category = "architecture"
    else:
        # If no specific topic category is found, use a default one
        topic_category = "performance"

    # Initialize an empty list to store potential questions
    question_set = []

    # Iterate over the questions in the evaluation criteria
    for _ in range(3):
        if random.random() < 0.5:
            question = random.choice(question_categories[topic_category]["question"])
            score = question_categories[topic_category][question]["score"]
            question_set.append({"question": question, "score": score})
        elif role == "Senior Software Engineer":
            # For senior roles, add more complex questions
            if random.random() < 0.3:
                question = f"What are some potential issues with {random.choice(question_categories['design']['question'])}?"
                score = 8
                question_set.append({"question": question, "score": score})
        elif role == "Software Engineer":
            # For junior roles, add simpler questions
            if random.random() < 0.2:
                question = f"What is your experience with {random.choice(question_categories['design']['question'].split(' '))}?"
                score = 4
                question_set.append({"question": question, "score": score})
        elif role == "Intern":
            # For interns, add very simple questions
            if random.random() < 0.1:
                question = f"Can you explain the basics of {random.choice(question_categories['design']['question'].split(' '))}?"
                score = 2
                question_set.append({"question": question, "score": score})

    return question_set

# Example usage:

candidate_persona = {
    "name": "John Doe",
    "role": "Senior Software Engineer",
    "topic": "microservices"
}

questions = generate_question_set(candidate_persona["role"], candidate_persona["topic"], candidate_persona)
for i, q in enumerate(questions):
    print(f"Question {i+1}: {q['question']}, Score: {q['score']}")
