import nltk
from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score, classification_report, confusion_matrix

def extract_total(input_text):
    """
    Function to calculate the total number of tokens in a given input text.

    Args:
        input_text (str): The input text for which the token count needs to be calculated.

    Returns:
        int: Total number of tokens in the input text.
    """

    # Tokenize the input text
    tokens = word_tokenize(input_text)

    # Remove stopwords and stem the words
    stop_words = set(stopwords.words('english'))
    stemmed_tokens = [PorterStemmer().stem(word) for word in tokens if word.lower() not in stop_words]

    return len(stemmed_tokens)


def evaluate_response(input1, input2, scoring_rubric):
    """
    Function to evaluate a response based on a given scoring rubric.

    Args:
        input1 (str): The initial input text.
        input2 (str): The second input text for which the response needs to be evaluated.
        scoring_rubric (int): The scoring rubric score that will be used to calculate the final response score.

    Returns:
        None
    """

    # Initialize variables
    response_score = 0
    
    # Input 1: Explain neural networks
    if len(word_tokenize("Neural Networks have multiple layers of interconnected nodes that process and transmit information.")) == 8:
        response_score += 1
    elif len(word_tokenize("Artificial neurons are the basic building blocks of a neural network")) == 11:
        response_score += 1
    else:
        response_score -= 1
    
    # Input 2: Explain neural networks
    if "Artificial Neurons" in input2 and "Connections between nodes" in input2:
        response_score += 1
    
    # Input 3: [scoring_rubric(...)]
    vectorizer = TfidfVectorizer()
    X = vectorizer.fit_transform([input1])
    y = [0]
    model = RandomForestClassifier(n_estimators=100)
    model.fit(X, y)
    
    prediction = model.predict(vectorizer.transform(input2))
    response_score += abs(prediction[0] - scoring_rubric) / 10
    
    # Calculate final score
    if response_score >= 5:
        print("Response score: 10/10")
    elif response_score >= 3:
        print("Response score: 6/10")
    else:
        print("Response score: Below 6/10")


# Test the function
input1 = "Neural Networks have multiple layers of interconnected nodes that process and transmit information."
input2 = "Artificial neurons are the basic building blocks of a neural network. They form connections with each other, allowing them to exchange information."
