### Overview

This is a simple REST API built using Node.js and Express.js, designed to manage tasks (to-dos) in a todo app. The API allows users to create, read, update, and delete tasks.

### API Endpoints

#### Task Creation

* **POST /tasks**: Create a new task
	+ Request Body: `taskName` (string)
	+ Response: Created task with ID and details
	+ Example: `curl -X POST -H "Content-Type: application/json" -d '{"taskName": "Buy milk"}' http://localhost:3000/tasks`

#### Task Reading

* **GET /tasks**: Retrieve all tasks
	+ Response: Array of tasks with IDs and details
	+ Example: `curl http://localhost:3000/tasks`
* **GET /tasks/:id**: Retrieve a single task by ID
	+ Response: Task with ID and details
	+ Example: `curl http://localhost:3000/tasks/1`

#### Task Update

* **PUT /tasks/:id**: Update a task by ID
	+ Request Body: `taskName` (string)
	+ Response: Updated task with new ID and details
	+ Example: `curl -X PUT -H "Content-Type: application/json" -d '{"taskName": "Buy eggs"}' http://localhost:3000/tasks/1`

#### Task Deletion

* **DELETE /tasks/:id**: Delete a task by ID
	+ Response: No response (204 Not Found)
	+ Example: `curl -X DELETE http://localhost:3000/tasks/1`

### API Implementation

```javascript
const express = require('express');
const app = express();
const port = 3000;
const tasks = [];

// Middleware for parsing JSON bodies
app.use(express.json());

// Create a new task
app.post('/tasks', (req, res) => {
    const { taskName } = req.body;
    if (!taskName) return res.status(400).json({ message: 'Task name is required' });

    tasks.push({ id: Date.now(), taskName });
    res.json(tasks[tasks.length - 1]);
});

// Retrieve all tasks
app.get('/tasks', (req, res) => {
    res.json(tasks);
});

// Retrieve a single task by ID
app.get('/tasks/:id', (req, res) => {
    const id = req.params.id;
    const task = tasks.find((task) => task.id === parseInt(id));
    if (!task) return res.status(404).json({ message: 'Task not found' });
    res.json(task);
});

// Update a task by ID
app.put('/tasks/:id', (req, res) => {
    const id = req.params.id;
    const taskIndex = tasks.findIndex((task) => task.id === parseInt(id));
    if (!taskIndex) return res.status(404).json({ message: 'Task not found' });

    const { taskName } = req.body;
    if (!taskName) return res.status(400).json({ message: 'Task name is required' });

    tasks[taskIndex].taskName = taskName;
    res.json(tasks[taskIndex]);
});

// Delete a task by ID
app.delete('/tasks/:id', (req, res) => {
    const id = req.params.id;
    const taskIndex = tasks.findIndex((task) => task.id === parseInt(id));
    if (!taskIndex) return res.status(404).json({ message: 'Task not found' });

    tasks.splice(taskIndex, 1);
});

// Start the server
app.listen(port, () => {
    console.log(`Server listening on port ${port}`);
});
```

### Example Use Cases

* Create a new task:
```bash
curl -X POST -H "Content-Type: application/json" -d '{"taskName": "Buy eggs"}' http://localhost:3000/tasks
```
Response: `{ id: 1643723401223, taskName: 'Buy eggs' }`

* Retrieve all tasks:
```bash
curl http://localhost:3000/tasks
```
Response: `[ { id: 1643723401223, taskName: 'Buy eggs' }, { id: 1643723401234, taskName: 'Buy milk' } ]`

* Update a task:
```bash
curl -X PUT -H "Content-Type: application/json" -d '{"taskName": "Buy bread"}' http://localhost:3000/tasks/1
```
Response: `{ id: 1643723401223, taskName: 'Buy bread' }`

* Delete a task:
```bash
curl -X DELETE http://localhost:3000/tasks/1
```

