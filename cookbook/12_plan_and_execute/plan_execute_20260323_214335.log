# filename: app/main.py

import json
from flask import Flask, request, jsonify

app = Flask(__name__)

class Todo:
    def __init__(self, title, description):
        self.title = title
        self.description = description
        self.done = False

class TodoApp:
    todos = []

    @classmethod
    def add_todo(cls, title, description):
        todo = Todo(title, description)
        cls.todos.append(todo)

    @classmethod
    def get_todos(cls):
        return cls.todos

    @classmethod
    def delete_todo(cls, index):
        if 0 <= index < len(cls.todos):
            del cls.todos[index]

def post_todo():
    title = request.json['title']
    description = request.json['description']
    TodoApp.add_todo(title, description)
    return jsonify({'message': 'Todo created successfully'}), 201

def get_todos():
    todos = TodoApp.get_todos()
    return jsonify([todo.__dict__.copy() for todo in todos]), 200

def delete_todo(index):
    TodoApp.delete_todo(index)
    return jsonify({'message': 'Todo deleted successfully'}), 204

@app.route('/todos', methods=['POST'])
def create_todo():
    return post_todo()

@app.route('/todos', methods=['GET'])
def get_all_todos():
    return get_todos()

@app.route('/todos/<int:index>', methods=['DELETE'])
def delete_todo_index(index):
    return delete_todo(index)

if __name__ == '__main__':
    app.run(debug=True)
