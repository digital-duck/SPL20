from flask import Flask, request, redirect, url_for
import uuid
import os
import hashlib
from flask_sqlalchemy import SQLAlchemy
from werkzeug.security import generate_password_hash, check_password_hash

app = Flask(__name__)
app.config['SQLALCHEMY_DATABASE_URI'] = 'postgresql://user:password@localhost/dbname'
db = SQLAlchemy(app)

class User(db.Model):
    id = db.Column(INT, PRIMARY KEY)
    username = db.Column(VARCHAR(50), UNIQUE=True)
    password_hash = db.Column(VARCHAR(255))

@app.route('/register', methods=['POST'])
def register_user():
    username = request.form['username']
    password = request.form['password']

    if User.query.filter_by(username=username).first():
        return 'Username already exists', 400

    user = User(username=username, password_hash=generate_password_hash(password))
    db.session.add(user)
    db.session.commit()

    return 'User created successfully'

@app.route('/login', methods=['POST'])
def login_user():
    username = request.form['username']
    password = request.form['password']

    user = User.query.filter_by(username=username).first()
    if not user or not check_password_hash(user.password_hash, password):
        return 'Invalid credentials', 401

    # Return the JWT token for the authenticated user
    return {'token': generate_token(user)}

@app.route('/shorten', methods=['POST'])
def shorten_url():
    long_url = request.form['long_url']
    short_url = uuid.uuid4().hex[:6]

    # Store the original URL with its corresponding shortened URL in the database
    db_url = Url(long_url=long_url, short_url=short_url)
    db.session.add(db_url)
    db.session.commit()

    return redirect(url_for('url', short_url=short_url))

@app.route('/<string:short_url>')
def url(short_url):
    # Retrieve the original URL from the database
    db_url = Url.query.filter_by(short_url=short_url).first()
    if not db_url:
        return 'URL not found', 404

    # Redirect to the original URL
    return redirect(db_url.long_url)

class Url(db.Model):
    id = db.Column(INT, PRIMARY KEY)
    user_id = db.Column(INT)
    long_url = db.Column(VARCHAR(255))
    short_url = db.Column(VARCHAR(50))

