**Flask App**

```python
from flask import Flask, request, jsonify
import redis
import uuid
from database import create_connection

app = Flask(__name__)

# Initialize Redis for caching purposes
redis_client = redis.Redis(host='localhost', port=6379, db=0)

# Connect to the database
db = create_connection()

def generate_shortened_url(long_url):
    # Generate a unique identifier for the shortened URL
    return str(uuid.uuid4())

def is_shortened_url_unique(shortened_url):
    # Check if the shortened URL already exists in the database
    return db.cursor().execute('SELECT 1 FROM urls WHERE shortened_url = ?', (shortened_url,)).fetchone() == None

def save_to_database(shortened_url, long_url):
    # Insert new record into the database with the corresponding shortened URL
    db.cursor().execute('INSERT INTO urls (original_url, shortened_url) VALUES (?, ?)', (long_url, shortened_url))
    db.commit()

@app.route('/shorten', methods=['POST'])
def shorten_url():
    try:
        long_url = request.json['url']
        if not is_shortened_url_unique(generate_shortened_url(long_url)):
            return jsonify({'error': 'Shortened URL already exists'}), 400
        save_to_database(generate_shortened_url(long_url), long_url)
        return jsonify({'shortened_url': generate_shortened_url(long_url)}), 200
    except Exception as e:
        print(f"Error shortening URL: {e}")
        return jsonify({'error': 'Internal Server Error'}), 500

@app.route('/get', methods=['GET'])
def get_long_url():
    try:
        shortened_url = request.args.get('shortenedUrl')
        if not shortened_url:
            return jsonify({'error': 'Missing shortened URL parameter'}), 400
        long_url = db.cursor().execute('SELECT original_url FROM urls WHERE shortened_url = ?', (shortened_url,)).fetchone()
        if not long_url:
            return jsonify({'error': 'Shortened URL does not exist'}), 404
        return jsonify({'longUrl': long_url[0]}), 200
    except Exception as e:
        print(f"Error retrieving URL: {e}")
        return jsonify({'error': 'Internal Server Error'}), 500

if __name__ == '__main__':
    app.run(debug=True)
```

