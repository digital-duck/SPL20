```python
from sqlalchemy import create_engine, Column, Integer, String, DateTime, ForeignKey, Table
from sqlalchemy.ext.declarative import declarative_base
from sqlalchemy.orm import sessionmaker, relationship

# Create a base class for all tables
Base = declarative_base()

class Url(Base):
    __tablename__ = 'urls'
    
    id = Column(Integer, primary_key=True)
    original_url = Column(String(200), nullable=False, unique=True)
    shortened_url = Column(String(10), nullable=False, unique=True)
    created_at = Column(DateTime, default=datetime.utcnow)

class User(Base):
    __tablename__ = 'users'
    
    id = Column(Integer, primary_key=True)
    username = Column(String(20), nullable=False, unique=True)
    password = Column(String(120), nullable=False)  # Store hashed password

url_user_table = Table('url_user', Base.metadata,
                        Column('url_id', Integer, ForeignKey('urls.id'), nullable=False),
                        Column('user_id', Integer, ForeignKey('users.id'), nullable=False))

def create_tables(engine):
    Base.metadata.create_all(engine)

engine = create_engine('sqlite:///url_shortener.db')

Session = sessionmaker(bind=engine)
session = Session()

# Define a function to shorten URLs and return the shortened URL
def short_url(long_url):
    try:
        url = session.query(Url).filter_by(original_url.long_url == long_url).first()
        if url:
            return url.shortened_url
        
        new_url = Url(original_url=long_url, shortened_url='XXXXX')
        session.add(new_url)
        session.commit()
        
        return 'XXXXX'
    except Exception as e:
        print(f"Error shortening URL: {e}")
        return None

# Define a function to retrieve the original long URL from the database
def get_long_url(shortened_url):
    try:
        url_entry = session.query(Url).filter_by(shortened_url=shortened_url).first()
        if not url_entry:
            return None
        
        return url_entry.original_url
    except Exception as e:
        print(f"Error retrieving URL: {e}")
        return None
