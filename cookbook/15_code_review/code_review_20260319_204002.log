class SeverityScore:
    def __init__(self):
        self.severity_score = 0

    def check_eval_vulnerability(self, input_function):
        try:
            result = input_function("1 + 2")
            if isinstance(result, str):
                raise SyntaxError("Invalid syntax")
            if not isinstance(result, (int, float)):
                raise ValueError("Undefined variable")
        except (SyntaxError, ValueError) as e:
            print(f"Eval vulnerability detected: {e}")
            self.severity_score += 1

    def check_code_injection(self, input_function):
        try:
            result = input_function("print('Hello, World!')")
            if isinstance(result, str):
                raise SyntaxError("Invalid syntax")
            if not isinstance(result, (int, float)):
                raise ValueError("Undefined variable")
        except (SyntaxError, ValueError) as e:
            print(f"Code injection vulnerability detected: {e}")
