import ast

def foo(x):
    try:
        if x.isnumeric():
            return int(x)
        elif x.replace('.', '', 1).replace('-', '', 1).isdigit(): # checks for valid float number 
            return float(x)
        else:
            raise ValueError(f"Invalid input: {x}")
    except ValueError as e:
        print(e)

def bar(y):
    try:
        if y.isnumeric():
            return int(y)
        elif y.replace('.', '', 1).replace('-', '', 1).isdigit(): # checks for valid float number 
            return float(y)
        else:
            raise ValueError(f"Invalid input: {y}")
    except ValueError as e:
        print(e)

def safe_eval(x):
    """
    Safely evaluate a string as Python expression.
    
    Args:
        x (str): The input string to be evaluated.
    
    Returns:
        result: The result of the evaluation.
    
    Raises:
        ValueError: If the input is not a valid Python expression.
    """
    try:
        return ast.literal_eval(x)
    except (ValueError, SyntaxError) as e:
        raise ValueError(f"Invalid input: {e}")
