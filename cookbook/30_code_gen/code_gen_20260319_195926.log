from email_validator import validate_email, EmailNotValidError

def is_valid_email(email):
    """
    Validate an email address.
    
    Args:
        email (str): The email address to be validated.
    
    Returns:
        bool: True if the email address is valid, False otherwise.
    """

    # Check if the input is empty or contains whitespace
    if not email.strip():
        return False

    try:
        # Validate the email address and get the result
        result = validate_email(email)
        
        # If the email address is valid, return True
        if result.status == 'valid':
            return True
        
        # If the email address is invalid, print an error message and return False
        else:
            print(f"Invalid email address: {result.error}")
            return False
    
    except EmailNotValidError as e:
        # If there's an error during validation, print an error message and return False
        print(f"Invalid email address: {e}")
        return False

