import unittest
from email_validator import EmailValidator

class AssembleOutput:
    def __init__(self):
        self.validator = EmailValidator()

    def assemble_output(self, emails: list[str]) -> dict[str, bool]:
        """
        Assembles the output for a given list of email addresses.

        Args:
            emails (list[str]): A list of email addresses to be validated.

        Returns:
            dict[str, bool]: A dictionary where keys are the email addresses and values are their corresponding validation results.
        """

        # Initialize an empty dictionary to store the validation results
        output = {}

        # Iterate over each email address in the input list
        for email in emails:
            try:
                # Validate the email address using the EmailValidator class
                output[email] = self.validator.validate_email(email)
            except Exception as e:
                print(f"Error occurred while validating email: {e}")
                output[email] = False

        return output


# Example usage:
assembler = AssembleOutput()
print(assembler.assemble_output(["example@example.com", "invalid_email", "test@example.co.uk"]))
```

